    <!-- ================= HERO ================= -->

    <section class="hero" id="home">

        <div class="hero-overlay">

            <h1>Form & Function</h1>

            <p>
                The Art of Designing Interior Spaces
            </p>

            <a href="#rooms" class="btn">
                Explore the Spaces
            </a>

        </div>

    </section>


    <!-- ================= INTRODUCTION ================= -->

    <section class="intro">

        <h2>Designing Spaces That Feel Like Home</h2>

        <p>

            Form and function are two of the most important ideas in
            interior design. Beautiful rooms should also be practical,
            comfortable, and designed around the people who use them.
            Through thoughtful layouts, furniture choices, lighting,
            colors, and materials, every room can become both visually
            appealing and functional.

        </p>

    </section>



    <!-- ================= EXPLORE ROOMS ================= -->

    <section id="rooms">

        <h2>Explore the Rooms</h2>

        <div class="room-container">

            <!-- Living Room -->

            <div class="room-card">

                <img src="images/living-room.jpg"
                    alt="Living Room">

                <h3>Living Room</h3>

                <p>

                    Comfortable gathering spaces designed for
                    relaxation and conversation.

                </p>

                <button
                    class="roomButton"
                    data-room="living">

                    View More

                </button>

            </div>


            <!-- Bedroom -->

            <div class="room-card">

                <img src="images/bedroom.jpg"
                    alt="Bedroom">

                <h3>Bedroom</h3>

                <p>

                    Calm, peaceful environments focused on
                    rest and organization.

                </p>

                <button
                    class="roomButton"
                    data-room="bedroom">

                    View More

                </button>

            </div>


            <!-- Kitchen -->

            <div class="room-card">

                <img src="images/kitchen.jpg"
                    alt="Kitchen">

                <h3>Kitchen</h3>

                <p>

                    Functional layouts that support cooking,
                    entertaining, and everyday living.

                </p>

                <button
                    class="roomButton"
                    data-room="kitchen">

                    View More

                </button>

            </div>


            <!-- Bathroom -->

            <div class="room-card">

                <img src="images/bathroom.jpg"
                    alt="Bathroom">

                <h3>Bathroom</h3>

                <p>

                    Spa-inspired spaces balancing comfort,
                    storage, and functionality.

                </p>

                <button
                    class="roomButton"
                    data-room="bathroom">

                    View More

                </button>

            </div>

        </div>

    </section>
